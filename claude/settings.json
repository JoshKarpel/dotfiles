{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:argo-cd.readthedocs.io)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.crossplane.io)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:docs.temporal.io)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:istio.io)",
      "WebFetch(domain:joshkarpel.github.io)",
      "WebFetch(domain:just.systems)",
      "WebFetch(domain:keepachangelog.com)",
      "WebFetch(domain:more-itertools.readthedocs.io)",
      "WebFetch(domain:packaging.python.org)",
      "WebFetch(domain:pre-commit.com)",
      "WebFetch(domain:pyo3.rs)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:sqlite.org)",
      "WebFetch(domain:webkit.org)",
      "WebFetch(domain:www.structlog.org)",
      "WebFetch(domain:www.w3.org)",
      "Edit(//tmp/**)",
      "Read(//tmp/**)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(pwd *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(strings *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse *)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh repo clone *)",
      "Bash(gh repo gitignore *)",
      "Bash(gh repo license *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh cache list *)",
      "Bash(gh search *)",
      "Bash(gh api graphql *)",
      "Bash(gh status *)",
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(cp *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(pre-commit run*)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl explain *)",
      "Bash(helm list*)",
      "Bash(helm status *)",
      "Bash(helm get *)",
      "Bash(helm show *)",
      "Bash(helm lint *)",
      "Bash(dyff *)",
      "Bash(* --version*)",
      "Bash(* --help*)"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git clean -f*)",
      "Bash(git restore .)",
      "Bash(git branch -D *)",
      "Bash(git remote set*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Bash(*.env*)",
      "Edit(**/uv.lock)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-just-list"
          },
          {
            "type": "command",
            "command": "claude-git-status"
          },
          {
            "type": "command",
            "command": "claude-gh-status"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claude-uv-check"
          },
          {
            "type": "command",
            "command": "claude-read-check"
          },
          {
            "type": "command",
            "command": "claude-shell-comment-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-git-add"
          },
          {
            "type": "command",
            "command": "claude-untracked-warn"
          },
          {
            "type": "command",
            "command": "claude-sound stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-sound notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline",
    "refreshInterval": 10
  },
  "voice": {
    "enabled": true,
    "mode": "hold",
    "autoSubmit": false
  },
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "acceptEdits",
  "effortLevel": "xhigh"
}
