{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:argo-cd.readthedocs.io)",
      "WebFetch(domain:asgi.readthedocs.io)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:datatracker.ietf.org)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.crossplane.io)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.langchain.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:docs.temporal.io)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:helm.sh)",
      "WebFetch(domain:istio.io)",
      "WebFetch(domain:joshkarpel.github.io)",
      "WebFetch(domain:just.systems)",
      "WebFetch(domain:keepachangelog.com)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:more-itertools.readthedocs.io)",
      "WebFetch(domain:packaging.python.org)",
      "WebFetch(domain:pre-commit.com)",
      "WebFetch(domain:pyo3.rs)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:pytest-asyncio.readthedocs.io)",
      "WebFetch(domain:python.temporal.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:sqlite.org)",
      "WebFetch(domain:support.langchain.com)",
      "WebFetch(domain:webkit.org)",
      "WebFetch(domain:www.structlog.org)",
      "WebFetch(domain:www.w3.org)",
      "Edit(//tmp/**)",
      "Read(//tmp/**)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(pwd *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(ast-grep *)",
      "Bash(strings *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse *)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh repo clone *)",
      "Bash(gh repo gitignore *)",
      "Bash(gh repo license *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh cache list *)",
      "Bash(gh search *)",
      "Bash(gh api graphql *)",
      "Bash(gh status *)",
      "Bash(gh run *)",
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv tree *)",
      "Bash(mise ls*)",
      "Bash(mise list*)",
      "Bash(mise ls-remote*)",
      "Bash(mise --version)",
      "Bash(mise doctor*)",
      "Bash(mise env*)",
      "Bash(mise outdated*)",
      "Bash(mise registry*)",
      "Bash(mise search*)",
      "Bash(mise config ls*)",
      "Bash(cp *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(pre-commit run*)",
      "Bash(claude-branch-journal*)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl api-resources *)",
      "Bash(helm list*)",
      "Bash(helm status *)",
      "Bash(helm get *)",
      "Bash(helm show *)",
      "Bash(helm lint *)",
      "Bash(dyff *)",
      "Bash(docker system df *)"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout .)",
      "Bash(git clean -f*)",
      "Bash(git restore .)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git remote set*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -fr ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -fr $HOME*)",
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Bash(*.env*)",
      "Edit(**/uv.lock)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "claude-just-list"
          },
          {
            "type": "command",
            "command": "claude-pre-commit-reminder"
          },
          {
            "type": "command",
            "command": "claude-python-version"
          },
          {
            "type": "command",
            "command": "claude-gh-status"
          },
          {
            "type": "command",
            "command": "claude-branch-journal"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-git-status"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claude-uv-check"
          },
          {
            "type": "command",
            "command": "claude-read-check"
          },
          {
            "type": "command",
            "command": "claude-shell-comment-check"
          },
          {
            "type": "command",
            "command": "claude-git-dash-c-check"
          },
          {
            "type": "command",
            "command": "claude-http-server-bind-check"
          },
          {
            "type": "command",
            "command": "claude-rm-scope-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-sound notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline",
    "refreshInterval": 10
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "high",
  "askUserQuestionTimeout": "never",
  "voice": {
    "enabled": true,
    "mode": "hold",
    "autoSubmit": false
  },
  "theme": "dark",
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}
