#!/usr/bin/env bash
# Stop hook: warn about untracked files, then stage tracked changes and run pre-commit if configured

set -euo pipefail

git rev-parse --show-toplevel &>/dev/null || exit 0

UNTRACKED=$(git ls-files --others --exclude-standard 2>/dev/null)
if [[ -n "$UNTRACKED" ]]; then
  jq -n --arg ctx "There are untracked files.
For each file, decide what to do with it: stage it with git add, add it to .gitignore, or delete it. If you're not sure, ask for help.
Files:

$UNTRACKED" '{"systemMessage":"[claude-stop-precommit] untracked files","hookSpecificOutput":{"hookEventName":"Stop","additionalContext":$ctx}}'
  exit 0
fi

if ! is-pre-commit-project; then
  git add --update
  exit 0
fi

if OUTPUT=$(pre-commit-autofix 2>&1); then
  exit 0
fi

jq -n --arg ctx "pre-commit is still failing after auto-fixing. Fix the issues before committing:

$OUTPUT" '{"systemMessage":"[claude-stop-precommit] pre-commit failing","hookSpecificOutput":{"hookEventName":"Stop","additionalContext":$ctx}}'
exit 0
