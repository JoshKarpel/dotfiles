#!/usr/bin/env bash
# Stop hook: nudge to update docs/tests/CLAUDE.md when the session changed something new

set -euo pipefail

INPUT=$(cat)
PORCELAIN=$(echo "$INPUT" | claude-changeset-guard followup) || exit 0

cat >&2 <<EOF
You made these changes this session:

$PORCELAIN

Before stopping, look for any additional followup work needed to keep things consistent, e.g. CLAUDE.md, documentation, changelogs, tests, justfile recipes, or code comments. These are examples, not a checklist: use your knowledge of this repo, what you've already done this session, and what you just changed to judge what (if anything) still needs to follow. Keep it scoped to consistency work the current change-set requires; don't start new work or expand scope. If nothing needs to follow, stop.
EOF
exit 2
