#!/usr/bin/env bash
# Stop hook orchestrator: run the blocking checks in sequence, then play the stop sound
# only if neither blocked — so the sound means Claude is actually stopping, not retrying
# after a block. (Hooks within a single Stop group run in parallel, so a separate sound
# hook can't know whether a sibling is about to block this same attempt.)

set -uo pipefail

INPUT=$(cat)

# If Claude's last message looks like a question, it's handing control back to the user.
# Don't let any check block the stop and force it to keep working — Claude is genuinely
# stopping to await a reply, so play the stop sound and let it stop.
LAST_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // ""')
if [[ "$LAST_MESSAGE" == *"?"* ]]; then
  claude-sound stop || true
  exit 0
fi

for check in claude-stop-precommit claude-stop-finish; do
  STDOUT=$(echo "$INPUT" | "$check")
  STATUS=$?
  if [[ $STATUS -ne 0 ]]; then
    exit "$STATUS"
  fi
  if [[ "${STDOUT:0:1}" == "{" ]]; then
    echo "$STDOUT"
    exit 0
  fi
done

claude-sound stop || true
exit 0
