#!/usr/bin/env bash
# PreToolUse hook: block `python -m http.server` without an explicit --bind.
# http.server defaults to binding all interfaces (0.0.0.0), exposing the server
# to the local network; a local static site almost always wants 127.0.0.1.

set -euo pipefail

# CLAUDE_HOOK_SELFTEST: set this env var to run the hook's embedded self-tests. This
# marker line is how `claude-hook-selftests` discovers participating hooks. The tests
# drive the hook through its own stdin interface (exit 2 = block, 0 = allow).
if [[ -n "${CLAUDE_HOOK_SELFTEST:-}" ]]; then
  fails=0
  t() {
    local want="$1" cmd="$2" got
    jq -cn --arg c "$cmd" '{tool_input: {command: $c}}' \
      | CLAUDE_HOOK_SELFTEST= "$0" >/dev/null 2>&1 && got=0 || got=$?
    [[ "$got" == "$want" ]] ||
    { printf 'FAIL want=%s got=%s :: %s\n' "$want" "$got" "$cmd"; fails=1; }
  }
  t 2 'python3 -m http.server'
  t 2 'python -m http.server 8000'
  t 2 'uv run python -m http.server'
  t 2 'python3 -m http.server 8080 --directory site'
  t 0 'python3 -m http.server --bind 127.0.0.1'
  t 0 'python3 -m http.server -b 127.0.0.1'
  t 0 'python3 -m http.server -b127.0.0.1'
  t 0 'python3 -m http.server --bind=0.0.0.0'
  t 0 'grep http.server file'
  t 0 'python3 -m http.client'
  t 0 'ls -la'
  if [[ "$fails" == 0 ]]; then
    echo "$(basename "$0"): all self-tests passed"
  fi
  exit "$fails"
fi

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Only fire on the http.server module invocation (python, python3, uv run python, etc.)
if ! echo "$COMMAND" | grep -qE '\-m[[:space:]]+http\.server'; then
  exit 0
fi

# Already binding explicitly (either --bind or the -b short form)? Nothing to do.
if echo "$COMMAND" | grep -qE '(\-\-bind|(^|[[:space:]])-b([[:space:]]|=|[0-9]))'; then
  exit 0
fi

echo "http.server binds all interfaces (0.0.0.0) by default, exposing it on the network. Pass '--bind 127.0.0.1' for a localhost-only server (or an explicit address if you truly need external access)." >&2
exit 2
