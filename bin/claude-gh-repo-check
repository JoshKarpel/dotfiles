#!/usr/bin/env bash
# PreToolUse hook: block gh repo view without an explicit repo argument;
# gh already defaults to the current repo, so using gh repo view to look up
# the current repo's own name (e.g. in a --repo $(...) subshell) is redundant.

set -euo pipefail

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Match commands that use --repo together with 'gh repo view' that has no explicit
# repo argument (next token is a flag or end-of-subshell), meaning it resolves to
# the current repo — which gh already defaults to, making --repo redundant.
if echo "$COMMAND" | grep -q -- '--repo' && echo "$COMMAND" | grep -qE 'gh repo view(\s+--?|\s*[)$]|\s*$)'; then
  echo "gh commands default to the current repo — 'gh repo view' with no explicit repo just resolves to the repo you're already in. Omit --repo entirely, or specify an explicit owner/repo if you're targeting a different one." >&2
  exit 2
fi

exit 0
