#!/usr/bin/env bash
# Stop hook: nudge to update docs/tests/CLAUDE.md when the session changed something

set -euo pipefail

INPUT=$(cat)
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
[[ "$STOP_HOOK_ACTIVE" == "true" ]] && exit 0

git rev-parse --show-toplevel >/dev/null 2>&1 || exit 0

# Only nudge when the session actually changed something (staged, unstaged, or untracked)
PORCELAIN=$(git status --porcelain 2>/dev/null)
[[ -z "$PORCELAIN" ]] && exit 0

# Skip if Claude's last message contains a `?` — likely awaiting a reply, not done yet.
# Simple and a bit broad (catches rhetorical questions too); tighten later if needed.
LAST_MESSAGE=$(echo "$INPUT" | jq -r '.last_assistant_message // ""')
[[ "$LAST_MESSAGE" == *"?"* ]] && exit 0

cat >&2 <<EOF
You made these changes this session:

$PORCELAIN

Before stopping, look for any followup work needed to keep things consistent, e.g.
CLAUDE.md, documentation, changelogs, tests, justfile recipes, or code comments. These
are examples, not a checklist: use your knowledge of this repo and what you just changed
to judge what (if anything) actually needs to follow. If nothing does, stop.
EOF
exit 2
