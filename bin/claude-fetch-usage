#!/usr/bin/env bash
# Fetch Claude Code usage limits from the Anthropic API, with caching.
# Outputs the raw JSON from the API, or exits silently if unavailable.
# Cache is stored globally (shared across Claude Code instances on this machine).

CACHE_FILE="${TMPDIR:-/tmp}/claude-usage-cache.json"
LOCK_FILE="${TMPDIR:-/tmp}/claude-usage-cache.lock"
CACHE_TTL=60 # seconds

cache_fresh() {
  [[ -f "$CACHE_FILE" ]] || return 1
  case "$(uname -s)" in
    Darwin) mtime=$(stat -f %m "$CACHE_FILE") ;;
    *) mtime=$(stat -c %Y "$CACHE_FILE") ;;
  esac
  (( $(date +%s) - mtime < CACHE_TTL ))
}

# Fast path: return cached result if still fresh (no lock needed)
if cache_fresh; then
  cat "$CACHE_FILE"
  exit 0
fi

# Slow path: acquire lock, re-check, then fetch
exec 9>"$LOCK_FILE"
flock 9

if cache_fresh; then
  cat "$CACHE_FILE"
  exit 0
fi

# Get the OAuth access token from platform-specific credential storage
get_token() {
  case "$(uname -s)" in
    Darwin)
      security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
        | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null
      ;;
    *)
      jq -r '.claudeAiOauth.accessToken // empty' \
        "${HOME}/.claude/.credentials.json" 2>/dev/null
      ;;
  esac
}

token=$(get_token)
if [[ -z "$token" ]]; then
  echo "claude-fetch-usage: no OAuth token found in credential store" >&2
  exit 0
fi

# Get Claude Code version for User-Agent header
cc_version=$(claude --version 2>/dev/null | awk '{print $1}')
cc_version="${cc_version:-unknown}"

# Fetch usage from the Anthropic API
response=$(curl -s \
    -H "Authorization: Bearer ${token}" \
    -H "Accept: application/json" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "User-Agent: claude-code/${cc_version}" \
    -w "\n%{http_code}" \
  "https://api.anthropic.com/api/oauth/usage" 2>&1)
http_status="${response##*$'\n'}"
body="${response%$'\n'*}"
if [[ "$http_status" != "200" || -z "$body" ]]; then
  echo "claude-fetch-usage: API request failed (HTTP ${http_status}): ${body}" >&2
  exit 0
fi
response="$body"

echo "$response" > "${CACHE_FILE}.tmp" && mv "${CACHE_FILE}.tmp" "$CACHE_FILE"
echo "$response"
