#!/usr/bin/env bash
# Print the repo's default branch name (e.g. main or master), or nothing.
# Tries origin/HEAD first, then falls back to a local main/master.

set -euo pipefail

DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||') || DEFAULT_BRANCH=""

if [[ -z "$DEFAULT_BRANCH" ]]; then
  if git show-ref --verify --quiet refs/heads/main; then
    DEFAULT_BRANCH="main"
  elif git show-ref --verify --quiet refs/heads/master; then
    DEFAULT_BRANCH="master"
  fi
fi

[[ -n "$DEFAULT_BRANCH" ]] && echo "$DEFAULT_BRANCH"
exit 0
