#!/usr/bin/env bash

set -euo pipefail

BASEDIR="$(dirname "$(dirname "$(realpath "$0")")")"
CLAUDE="$BASEDIR/claude"
BACKUPS=~/.dotfiles-backups

mkdir -p ~/.claude

while IFS= read -r -d '' file; do
  rel="${file#"$CLAUDE"/}"
  target=~/.claude/"$rel"

  mkdir -p "$(dirname "$target")"

  if [[ -e "$target" && ! -L "$target" ]]; then
    mkdir -p "$BACKUPS"
    backup="$BACKUPS/$(basename "$target")"
    echo "mv $target -> $backup"
    mv "$target" "$backup"
  fi

  echo "link $target -> $file"
  ln -sf "$file" "$target"
done < <(find "$CLAUDE" -type f -print0)

# prune symlinks that point into $CLAUDE but whose target no longer exists
while IFS= read -r -d '' link; do
  if [[ "$(readlink "$link")" == "$CLAUDE"/* && ! -e "$link" ]]; then
    echo "prune $link"
    rm "$link"
  fi
done < <(find ~/.claude -maxdepth 1 -type l -print0; find ~/.claude/rules ~/.claude/skills -type l -print0 2>/dev/null)

# remove skill directories emptied by pruning
find ~/.claude/skills -type d -empty -delete 2>/dev/null || true
