#!/usr/bin/env bash
# SessionStart hook: show git status

set -euo pipefail

STATUS=$(git status --short --branch 2>/dev/null) || exit 0

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null) || CURRENT_BRANCH=""
DEFAULT_BRANCH=$(git-default-branch)

cat <<EOF
Current git status:

$STATUS
EOF

if [[ -n "$CURRENT_BRANCH" && -n "$DEFAULT_BRANCH" && "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]]; then
  LOG=$(git log "${DEFAULT_BRANCH}..HEAD" --oneline --stat 2>/dev/null)
  if [[ -n "$LOG" ]]; then
    cat <<EOF

Recent commits:

$LOG
EOF
  fi

  # Net diff vs. the merge-base (three-dot): each file once, cumulative change,
  # collapsing per-commit churn. Orients a cold session on what the branch amounts to.
  DIFFSTAT=$(git diff "${DEFAULT_BRANCH}...HEAD" --stat 2>/dev/null)
  if [[ -n "$DIFFSTAT" ]]; then
    cat <<EOF

Net changes vs. ${DEFAULT_BRANCH} (merge-base):

$DIFFSTAT
EOF
  fi
fi
