#!/usr/bin/env bash
# PreToolUse hook: block sed/head/tail used just to read file line ranges;
# the Read tool handles this natively with offset/limit and doesn't need approval.

set -euo pipefail

# CLAUDE_HOOK_SELFTEST: set this env var to run the hook's embedded self-tests. This
# marker line is how `claude-hook-selftests` discovers participating hooks. The tests
# drive the hook through its own stdin interface (exit 2 = block, 0 = allow).
if [[ -n "${CLAUDE_HOOK_SELFTEST:-}" ]]; then
  fails=0
  t() {
    local want="$1" cmd="$2" got
    jq -cn --arg c "$cmd" '{tool_input: {command: $c}}' \
      | CLAUDE_HOOK_SELFTEST= "$0" >/dev/null 2>&1 && got=0 || got=$?
    [[ "$got" == "$want" ]] ||
    { printf 'FAIL want=%s got=%s :: %s\n' "$want" "$got" "$cmd"; fails=1; }
  }
  t 2 "sed -n '1,5p' file.txt"
  t 2 'sed -n 1,5p file.txt'
  t 2 'head -n 20 file.txt'
  t 2 'tail -n 5 app.log'
  t 0 "sed -n '5p' file"
  t 0 'sed -i s/a/b/ file'
  t 0 'head -c 100 file'
  t 0 'cat file | head -n 5'
  t 0 'tail -f log'
  t 0 'ls -la'
  if [[ "$fails" == 0 ]]; then
    echo "$(basename "$0"): all self-tests passed"
  fi
  exit "$fails"
fi

INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

# Detect: sed -n 'X,Yp' file  (line-range reads)
if echo "$COMMAND" | grep -qE "sed\s+-n\s+['\"]?[0-9]+,[0-9]+p['\"]?"; then
  echo "Use the Read tool with 'offset' and 'limit' parameters instead of 'sed -n X,Yp'. It reads line ranges natively and doesn't require Bash approval." >&2
  exit 2
fi

# Detect: head -n N file  (reading first N lines of a file, not in a pipeline)
if echo "$COMMAND" | grep -qE "^head\s+-n\s+[0-9]+\s+\S+$"; then
  echo "Use the Read tool with 'limit' instead of 'head -n N file'. It reads the first N lines natively and doesn't require Bash approval." >&2
  exit 2
fi

# Detect: tail -n N file  (reading last N lines of a file, not in a pipeline)
if echo "$COMMAND" | grep -qE "^tail\s+-n\s+[0-9]+\s+\S+$"; then
  echo "Use the Read tool instead of 'tail -n N file'. Read the file with an appropriate offset (use 'wc -l' first if needed to find the line count). This avoids Bash approval." >&2
  exit 2
fi

exit 0
